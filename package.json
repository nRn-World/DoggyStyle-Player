{
  "name": "react-example",
  "private": true,
  "version": "1.1.6",
  "description": "Doggy Video Player",
  "author": "nRn World",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "dev:electron": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "build:electron": "npm run build && electron-builder --win",
    "build:electron:mac": "npm run build && electron-builder --mac",
    "build:electron:linux": "npm run build && electron-builder --linux",
    "build:electron:all": "npm run build && electron-builder --win --mac --linux",
    "build:electron:zip": "npm run build && electron-builder --win zip"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "jimp": "^1.6.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.doggy.player",
    "productName": "Doggy Player",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "Logo Bilder/icon.png",
      "artifactName": "Doggy-Player-Setup-${version}.${ext}",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "mac": {
      "icon": "Logo Bilder/icon.png",
      "category": "public.app-category.video",
      "artifactName": "Doggy-Player-${version}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "Logo Bilder/icon.png",
      "category": "Video",
      "artifactName": "Doggy-Player-${version}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Doggy Player",
      "license": "LICENSE.txt"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "Logo Bilder/logomp4.mp4",
      "Logo Bilder/icon.png"
    ],
    "publish": {
      "provider": "github",
      "owner": "nRn-World",
      "repo": "Doggy-Player"
    }
  }
}
